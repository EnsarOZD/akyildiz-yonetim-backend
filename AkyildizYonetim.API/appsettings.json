{
  "RunMigrationsOnStartup": true,
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_IP;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "AkyildizYonetim",
    "Audience": "AkyildizYonetimClient",
    "ExpirationInMinutes": 60
  },
  "ClientSettings": {
    "ClientUrl": "https://www.akyildizyonetim.com,https://akyildizyonetim.com"
  },
  "SmtpSettings": {
    "Host": "mail.kurumsaleposta.com",
    "Port": 587,
    "User": "[EMAIL_ADDRESS]",
    "Password": "[smtp_password]",
    "From": "[EMAIL_ADDRESS]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}